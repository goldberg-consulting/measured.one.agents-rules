# Project paths for install-all.sh
# Add one path per line. Lines starting with # are ignored.
# Use ~ for home directory. Paths that don't exist are skipped.

PROJECTS="
~/projects/my-first-project
~/projects/my-second-project
"

# Optional: path to the reference database build repo
# REFERENCE_DB_REPO=~/reference-db-builder
#
# Backward-compatible alias used by older installer versions:
# CODE_LOOK_ME_UP=~/code-look-me-up

# Optional: set to "1" to force-rebuild the reference database during install
# REBUILD_DB=0
